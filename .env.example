# Cloud Atlas Bot — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# Supabase project configuration
# The anon (publishable) key is safe to expose in frontend code.
# The service role key MUST be kept secret — only used in Edge Functions via Deno.env.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_REF"

# Supabase Edge Function secrets (set via Supabase Dashboard > Project Settings > Edge Functions)
# Do NOT put these in .env — they must be set as Supabase secrets, not in this file.
# SUPABASE_SERVICE_ROLE_KEY=  <-- set in Supabase dashboard only
# ENCRYPTION_KEY=             <-- set in Supabase dashboard only
# RESEND_API_KEY=             <-- set in Supabase dashboard only
# TELEGRAM_BOT_TOKEN=         <-- set in Supabase dashboard only
# TELEGRAM_CHAT_ID=           <-- set in Supabase dashboard only
# KRAKEN_API_KEY=             <-- REMOVED: per-user keys are stored encrypted in the database
# KRAKEN_PRIVATE_KEY=         <-- REMOVED: per-user keys are stored encrypted in the database
