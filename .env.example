# Example environment configuration for Cloud Atlas Trading Dashboard
# Copy this file to .env and fill in the values for your Supabase project.
#
# ⚠  VITE_SUPABASE_PUBLISHABLE_KEY must be the JWT anon key (starts with eyJ…),
#    NOT the sb_publishable_… key shown in the new Supabase "API Keys" tab.
#    Get it from: Dashboard → Settings → API Keys → Legacy → anon (public)

VITE_SUPABASE_PROJECT_ID=mhaggmeoxdepwyshkyff
VITE_SUPABASE_URL=https://mhaggmeoxdepwyshkyff.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<your-anon-payload>.<your-anon-signature>

# Never commit the real service-role key — used by edge functions only
# VITE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<service-role-payload>.<signature>
